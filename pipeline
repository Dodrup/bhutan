pipeline {
    agent any

    parameters {
        choice(name: 'ACTION', choices: ['build', 'deploy'], description: 'Choose action')
    }

    stages {

        stage('Build') {
            when {
                expression {
                    params.ACTION == 'build'
                }
            }

            steps {
                echo 'Building application...'
            }
        }

        stage('Deploy') {
            when {
                expression {
                    params.ACTION == 'deploy'
                }
            }

            steps {
                echo 'Deploying application...'
            }
        }
    }
}


pipeline {
    agent any

    parameters {
        choice(name: 'ACTION', choices: ['build', 'test', 'deploy'], description: 'Choose action')
    }

    stages {

        stage('Build') {
            when {
                expression {
                    params.ACTION == 'build'
                }
            }

            steps {
                echo 'Building application...'
            }
        }

        stage('Test') {
            when {
                expression {
                    params.ACTION == 'test'
                }
            }

            steps {
                echo 'Running tests...'
            }
        }

        stage('Deploy') {
            when {
                expression {
                    params.ACTION == 'deploy'
                }
            }

            steps {
                echo 'Deploying application...'
            }
        }
    }
}
