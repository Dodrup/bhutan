pipeline {
    agent any  // This agent will apply to the entire pipeline (default for all stages)
    
    stages {
        // Stage with pipeline-level agent
        stage('Build') {
            steps {
                echo 'This is the Build stage, using the pipeline agent (any available agent).'
            }
        }

        // Stage with a specific agent defined at the stage level
        stage('Test') {
            agent any  // Use any available agent for this stage (no need for a label like 'linux')
            steps {
                echo 'This is the Test stage, using a specific agent (any available agent).'
            }
        }

        // Stage with pipeline-level agent again
        stage('Deploy') {
            steps {
                echo 'This is the Deploy stage, using the pipeline agent (any available agent).'
            }
        }
    }
}
